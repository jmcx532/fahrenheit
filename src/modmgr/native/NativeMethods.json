// The guideline for these options was:
// - we specifically want blittable structs, _not_ interfaces
// - we prefer 'raw' or 'unfriendly' overloads, and accept the resulting complexity
{
    "$schema": "https://aka.ms/CsWin32.schema.json",
    "public": true,
    "wideCharOnly": false,
    "allowMarshaling": false,
    "friendlyOverloads": {
        "enabled": false
    }
}
